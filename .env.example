# Copy to .env (do not commit .env). Use RACK_ENV only — not API_RACK_ENV.

# --- required ---
RACK_ENV=development
RACK_SESSION_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

POSTGRES_HOST= # for local docker run set to protectedplanet-db (same as in docker-compose.yml), for local run without docker set to localhost
POSTGRES_PORT= # for local docker run set to 5432 (same as in docker-compose.yml), for local run without docker set to 5441 or other port.
POSTGRES_DBNAME=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_TEST_DBNAME=pp_test
PUMA_MIN_THREADS=1
PUMA_MAX_THREADS=5
PUMA_WORKERS=5 # 5 is for production or local docker running, for local run without docker set to 0
ADMIN_USERNAME=username # for admin page login
ADMIN_PASSWORD=password # for admin page login

# Browser CORS allowlist (comma-separated origins, e.g. https://www.protectedplanet.net,http://localhost:3000).
# Development/test: empty or unset allows any origin (*), same as historical behaviour.
# Staging/production: MUST be non-empty — the app refuses to boot without an explicit list.
CORS_ORIGINS=

# If running without docker then bind to localhost, NO NEED for local docker or production
PUMA_BIND=localhost

# SMTP mailer settings (required for staging/production only).
# In local Docker development, these are provided by ProtectedPlanet docker-compose for MailHog.
MAILER_AUTHENTICATION=login # likely to be login for most SMTP servers
MAILER_ADDRESS=smtp.server.com
MAILER_DOMAIN=domain.com
MAILER_USERNAME=username
MAILER_PASSWORD=password
MAILER_HOST=domain.com
MAILER_PORT=25



# prod / staging ONLY. NO NEED for local run
APPSIGNAL_PUSH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APPSIGNAL_APP_NAME=protectedplanet-api
APPSIGNAL_LOG_PATH=log/appsignal.log
APPSIGNAL_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# optional in all environments
# PUMA_PIDFILE=tmp/pids/puma.pid
